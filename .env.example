# ── Frontend (VITE_ prefix = exposed to browser) ──────────────────────────────
VITE_API_BASE=https://corsproxy.io/?https://<your-api-gateway-id>.execute-api.<region>.amazonaws.com/prod
VITE_API_KEY=your_api_key_here
VITE_CHATBOT_API_URL=https://<your-chatbot-api-id>.execute-api.<region>.amazonaws.com/prod/chat
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Backend (Vercel serverless functions — AI Coach) ───────────────────────────
# Provider: "bedrock" or "anthropic"
AI_PROVIDER=bedrock
AWS_BEDROCK_API_KEY=your-bedrock-api-key
AWS_REGION=us-east-1

# Only needed if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Supabase (server-side — can use service role key for full access)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=

# AI model defaults
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5
ANTHROPIC_EXTRACT_MODEL=claude-haiku-4-5
DEFAULT_NUDGE_LIMIT=2
CHAT_MAX_TOKENS=2048
SUMMARY_MAX_TOKENS=512
EXTRACTION_MAX_TOKENS=512
EVIDENCE_MAX_TOKENS=400
MIN_MESSAGES_TO_SUMMARIZE=4
CHECKIN_WINDOW_DAYS=7
