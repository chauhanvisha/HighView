# Environment Variables for HighView
# Copy this file to .env and fill in your values

VITE_API_BASE=https://corsproxy.io/?https://<your-api-gateway-id>.execute-api.<region>.amazonaws.com/prod
VITE_API_KEY=your_api_key_here
VITE_CHATBOT_API_URL=https://<your-chatbot-api-id>.execute-api.<region>.amazonaws.com/prod/chat
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
